# ATMS Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ──
# For PostgreSQL (production): set DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# For SQLite (local dev): leave DATABASE_URL unset (auto uses data/atms.db)

# ── Server ──
PORT=8080
ATMS_DEBUG=false

# ── SMTP Email Configuration ──
# Required for transactional email delivery (notifications, approvals, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=ATMS System <your-email@gmail.com>

# For Gmail: Use App Passwords (https://myaccount.google.com/apppasswords)
# For Office 365: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# For AWS SES: SMTP_HOST=email-smtp.us-east-1.amazonaws.com, SMTP_PORT=587

# ── Authentication ──
# TOKEN_SECRET is auto-generated if not set (uses os.urandom)
# TOKEN_SECRET=your-secret-key-here

# ── Render.com Deployment ──
# RENDER=true (auto-set by Render)

# ── Anthropic / Claude (for AI image-parsing of non-standard daily reports) ──
# Required for the "이미지/비규격 형식 AI 분석" uploader on the 조종사 현황 → 업로드 관리 tab.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional override — defaults to claude-opus-4-6
# CLAUDE_VISION_MODEL=claude-opus-4-6
